# DOMUS Environment Configuration
# Copy this file to .env and fill in your values

# REQUIRED: Generate a strong secret (64+ characters)
# Use: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_strong_secret_here

# Server configuration
NODE_ENV=development
PORT=4000

# PostgreSQL connection string
# Local development:
DATABASE_URL=postgresql://domus:domus_secret@localhost:5432/domus_db

# Fly.io sets DATABASE_URL automatically when you attach a Postgres cluster
# FRONTEND_URL=https://domus-app.fly.dev
